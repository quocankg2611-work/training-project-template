{
  "compilerOptions": {
    "module": "es2020",
    "target": "es2020",
    "outDir": "./dist/",
    "noImplicitAny": true,
    "jsx": "react",
    "allowJs": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "strict": false
  },
  "exclude": [
    "node_modules",
    "dist",
    "assets",
    "__tasks__"
  ]
}